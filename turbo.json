{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**"]
    },
     "start": {
      "dependsOn": ["build"],
      "cache": false
    },
    "lint": {},
    "type-check": {}
  }
}